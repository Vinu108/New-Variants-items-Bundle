<script>
document.getElementById("customAddToCart").addEventListener("click", async function () {

  const isSubscription = document.getElementById("subscriptionCheck")?.checked;

  const wrapper = isSubscription
    ? document.querySelector(".wrapper_bundles_with_subscripton")
    : document.querySelector(".wrapper_bundles_without_subscripton");

  if (!wrapper) return;

  const activeBundle = wrapper.querySelector(".bundle-box.active");
  if (!activeBundle) return;

  const bundleIndex = activeBundle.getAttribute("data_index");

  const getInt = (v) => parseInt(v);

  let items = [];

  // =====================================
  // 1. COLLECT ALL SELECTED VARIANTS
  // =====================================
  const selects = activeBundle.querySelectorAll(".variant-select");

  selects.forEach(select => {

    const variantId = getInt(select.value);

    const existing = items.find(item => item.id === variantId);

    if (existing) {
      existing.quantity += 1;
    } else {
      items.push({
        id: variantId,
        quantity: 1,
        properties: isSubscription
          ? { _subscription: "true" }
          : {}
      });
    }

  });

  // =====================================
  // 2. GIFT LOGIC
  // =====================================

  const gift1 = activeBundle.getAttribute("var_id_two");
  const gift2 = activeBundle.getAttribute("var_id_three");
  const gift3 = activeBundle.getAttribute("var_id_four");

  if (bundleIndex === "2") {

    if (gift1) {
      items.push({
        id: getInt(gift1),
        quantity: 1,
        properties: {
          _bundle: isSubscription
            ? "Subscription Gift"
            : "Buy 2 Get 1 Free - Gift"
        }
      });
    }

  } 
  else if (bundleIndex === "3") {

    if (gift1) {
      items.push({
        id: getInt(gift1),
        quantity: 1,
        properties: {
          _bundle: isSubscription
            ? "Subscription Gift"
            : "Buy 3 Get 2 Free - Gift"
        }
      });
    }

    if (gift2) {
      items.push({
        id: getInt(gift2),
        quantity: 1,
        properties: {
          _bundle: isSubscription
            ? "Subscription Gift"
            : "Extra Gift"
        }
      });
    }

  }

  // =====================================
  // 3. ADD TO CART
  // =====================================
  try {

    const res = await fetch("/cart/add.js", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ items })
    });

    const data = await res.json();

    console.log("Cart updated:", data);

    window.location.href = "/checkout";

  } catch (err) {
    console.error("Cart error:", err);
  }

});
</script>




<script>
document.querySelectorAll('.bundle-box').forEach(function(box) {
  box.addEventListener('click', function() {
    // Get the parent wrapper (with or without subscription)
    var wrapper = this.closest('.wrapper_bundles_without_subscripton, .wrapper_bundles_with_subscripton');
    // Remove active from all siblings
    wrapper.querySelectorAll('.bundle-box').forEach(function(b) {
      b.classList.remove('active');
    });
    // Add active to clicked
    this.classList.add('active');
  });
});

</script>



<script>
$(document).ready(function () {
  var data_index = '';
$('#subscriptionCheck').prop('checked', true); 
  function toggleSubscription() {


    // Get active bundle index first
    $('.bundle-box.active').each(function () {
      data_index = $(this).attr('data_index'); // or .data('index')
    });


    if ($('#subscriptionCheck').is(':checked')) {


      $('#subscriptionBox').addClass('active');
      $('.wrapper_bundles_with_subscripton').show();
      $('.wrapper_bundles_without_subscripton').hide();


      $('.wrapper_bundles_with_subscripton .bundle-box[data_index="' + data_index + '"]')
        .trigger('click');


    } else {


      $('#subscriptionBox').removeClass('active');
      $('.wrapper_bundles_with_subscripton').hide();
      $('.wrapper_bundles_without_subscripton').show();


      $('.wrapper_bundles_without_subscripton .bundle-box[data_index="' + data_index + '"]')
        .trigger('click');
    }
  }


  // Initial run
  toggleSubscription();


  // On checkbox change
  $('#subscriptionCheck').on('change', function () {
    toggleSubscription();
  });


});


</script>

